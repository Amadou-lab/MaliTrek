rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net (Catch-all Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES & HELPERS ---
    function isSignedIn() { return request.auth != null; }
    
    // Mandate email verification for all writes (except for hardcoded admins or system checks)
    function isVerified() { 
      return isSignedIn() && (
        request.auth.uid in ['Unl5AWrKAbcUX2L3OzI5uWlXpJ32', 'dqNQXhPgSYOaftuX8IIcefKG2eY2'] || 
        request.auth.token.get('email_verified', false) == true || 
        request.auth.token.get('email', '') in [
          'diabateamadou88@gmail.com', 'admin@malitrek.com', 'client@malitrek.com',
          'client2@malitrek.com', 'client3@malitrek.com', 'guide@malitrek.com', 'guide1@malitrek.com'
        ]
      );
    }
    
    // Trusted emails for admins
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.get('email', '') in ['diabateamadou88@gmail.com', 'admin@malitrek.com'] ||
        request.auth.uid in ['Unl5AWrKAbcUX2L3OzI5uWlXpJ32', 'dqNQXhPgSYOaftuX8IIcefKG2eY2'] ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- USERS ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isVerified() && isOwner(userId) && incoming().uid == userId;
      allow update: if (isOwner(userId) || isAdmin()) || 
        // Action: Update stats from review
        (isVerified() && incoming().diff(existing()).affectedKeys().hasAny(['ratingSum', 'reviewCount', 'rating', 'averageRating'])) ||
        // Action: System balance update
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasAny(['balancePending', 'balanceAvailable', 'totalEarned', 'lastActivityAt', 'balanceBlocked', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // --- CIRCUITS ---
    match /circuits/{circuitId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(circuitId);
      allow update: if (isVerified() && (existing().guideId == request.auth.uid || isAdmin())) ||
        // Action: Update stats from review
        (isVerified() && incoming().diff(existing()).affectedKeys().hasAny(['ratingSum', 'reviewCount', 'averageRating']));
      allow delete: if isAdmin();
    }

    // --- JOURNEYS --- 
    match /journeys/{journeyId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(journeyId) && (incoming().get('guideId', '') == request.auth.uid || isAdmin());
      allow update: if isVerified() && (
        (request.auth.uid == 'dqNQXhPgSYOaftuX8IIcefKG2eY2') ||
        (request.auth.uid == 'Unl5AWrKAbcUX2L3OzI5uWlXpJ32') ||
        (existing().get('guideId', '') == request.auth.uid) || 
        isAdmin() || 
        // Action: Sync
        (incoming().diff(existing()).affectedKeys().hasAny([
          'availableSeats', 'status', 'updatedAt', 'currentParticipants', 
          'incidentCount', 'activeParticipantsCount', 'checkedInCount', 'itineraryStatus',
          'startedAt', 'completedAt', 'confirmedReservationsCount', 'activeReservationsCount',
          'itineraryProgress', 'currentStepIndex', 'deadlineForAutoValidation'
        ]))
      );
      allow delete: if isAdmin();
    }

    // --- RESERVATIONS --- 
    match /reservations/{reservationId} {
      function isReservationParty() {
        return (existing().get('userId', '') == request.auth.uid) || 
               (existing().get('guideId', '') == request.auth.uid) ||
               isAdmin();
      }

      allow read: if isSignedIn() && isReservationParty();
      
      allow create: if isVerified() && isValidId(reservationId) && incoming().get('userId', '') == request.auth.uid;
      
      allow update: if isVerified() && (
        (request.auth.uid == 'dqNQXhPgSYOaftuX8IIcefKG2eY2') ||
        (request.auth.uid == 'Unl5AWrKAbcUX2L3OzI5uWlXpJ32') ||
        (isReservationParty() || isAdmin()) && (
          // Action: Guide Full Access
          (existing().get('guideId', '') == request.auth.uid) ||

        // Action: Client Check-in
        (existing().get('userId', '') == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['clientCheckInStatus', 'clientCheckedInAt', 'presenceConflict', 'updatedAt'])) ||
        
        // Action: Client Validate Experience (Release Funds)
        (existing().get('userId', '') == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasAny([
           'status', 'paymentStatus', 'commissionStatus', 'releasedAmount', 
           'releasedAt', 'releaseType', 'experienceValidated', 'autoValidated', 
           'validatedAt', 'updatedAt'
         ])) ||
        
        // Action: Confirm Payment (Initial)
        (existing().get('userId', '') == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'paymentStatus', 'updatedAt'])) ||

        // Action: Cancellation
        (existing().get('userId', '') == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'cancellationRequestedAt', 'cancellationReason', 'updatedAt', 'cancellationStatus'])) ||

        // Action: Mark Reviewed
        (existing().get('userId', '') == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['reviewId', 'updatedAt'])) ||

        isAdmin()
      ) );
      
      allow delete: if isAdmin();
    }

    match /reservationEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    // --- MESSAGING ---
    match /conversations/{conversationId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isVerified();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- FINANCIALS ---
    match /transactions/{txId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{reqId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.guideId == request.auth.uid);
      allow create: if isVerified() && incoming().guideId == request.auth.uid;
      allow update: if isAdmin();
    }

    // --- REVIEWS & DISPUTES ---
    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid || resource.data.guideId == request.auth.uid);
      allow create: if isVerified();
      allow update: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- AUDIT & INCIDENTS ---
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /incidents/{incidentId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.guideId == request.auth.uid));
      allow create: if isSignedIn();
    }

    match /cancellations/{cancelId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.guideId == request.auth.uid));
      allow create: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
    
    match /pois/{poiId} { allow read: if true; allow write: if isAdmin(); }
    match /favorites/{favId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
  }
}
